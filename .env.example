# InvoiceGenie environment template — copy to .env and fill secrets.
# NEVER commit real secrets. .env is gitignored.

# --- OWASP / security scanning ---
NVD_API_KEY=

# --- Postgres (production / docker-compose) ---
POSTGRES_USER=ar
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=invoicegenie
QUARKUS_DATASOURCE_USERNAME=ar
QUARKUS_DATASOURCE_PASSWORD=change-me-strong-password
QUARKUS_DATASOURCE_JDBC_URL=jdbc:postgresql://postgres:5432/invoicegenie

# --- API security (required when quarkus.profile=prod) ---
INVOICEGENIE_SECURITY_ENABLED=true
INVOICEGENIE_SECURITY_MODE=api-key
# Format: apiKey:tenantUuid  (comma-separated for multiple)
INVOICEGENIE_API_KEYS=dev-local-key:00000000-0000-0000-0000-000000000001
# For jwt mode:
# INVOICEGENIE_SECURITY_MODE=jwt
# INVOICEGENIE_JWT_SECRET=replace-with-long-random-secret
INVOICEGENIE_SECURITY_ALLOW_OPENAPI=false

# --- Web ---
BACKEND_URL=http://app:8080
NEXT_PUBLIC_APP_NAME=InvoiceGenie AR
NEXT_PUBLIC_ALLOW_TENANT_OVERRIDE=false
NEXT_PUBLIC_DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001
# Optional browser API key (same as INVOICEGENIE_API_KEYS key part)
NEXT_PUBLIC_API_KEY=dev-local-key

# --- Runtime ---
QUARKUS_HTTP_PORT=8080
QUARKUS_PROFILE=prod
