        <mxCell id="agg5" value="Events&#xa;InvoiceIssued&#xa;Payment*" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="dom">
