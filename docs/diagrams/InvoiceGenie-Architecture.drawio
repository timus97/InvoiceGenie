  <diagram id="data" name="Domain Data Design">
    <mxGraphModel dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="tt" value="Domain &amp; Data Design — Multi-tenant AR" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontStyle=1;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="180" y="8" width="440" height="24" as="geometry"/>
        </mxCell>

        <mxCell id="tenant" value="ar_tenant&#xa;id · name · slug · base_currency" style="shape=table;startSize=0;container=0;collapsible=0;childLayout=tableLayout;fixedRows=1;rowLines=0;fontStyle=1;align=center;resizeLast=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="40" width="240" height="50" as="geometry"/>
