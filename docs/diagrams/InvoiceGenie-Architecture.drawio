        <mxCell id="inv" value="Invoice ★&#xa;ar_invoice&#xa;status · totals · version&#xa;customer_ref" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="240" y="130" width="150" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="pay" value="Payment ★&#xa;ar_payment&#xa;amount_unallocated&#xa;method · status" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="460" y="130" width="150" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="chq" value="Cheque&#xa;ar_cheque&#xa;RECEIVED→…→CLEARED" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="660" y="130" width="100" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="line" value="InvoiceLine&#xa;ar_invoice_line&#xa;(tenant, inv, seq)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="240" y="250" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="alloc" value="PaymentAllocation&#xa;ar_payment_allocation&#xa;payment ↔ invoice $" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="350" y="250" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="cn" value="CreditNote&#xa;ar_credit_note&#xa;EPD 2%" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="560" y="250" width="110" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="led" value="LedgerEntry&#xa;AR · REVENUE · BANK · EXPENSE&#xa;(domain enum; in-mem adapter)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="360" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="out" value="OutboxEntry&#xa;ar_outbox&#xa;PENDING→PUBLISHED" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="280" y="360" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="aud" value="AuditEntry&#xa;ar_audit_log&#xa;before/after state" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="480" y="360" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="fx" value="ExchangeRate&#xa;schema-only" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#999999;fontSize=9;fontStyle=2;align=center;" vertex="1" parent="1">
          <mxGeometry x="660" y="360" width="100" height="50" as="geometry"/>
        </mxCell>

        <!-- Multi-tenancy box -->
        <mxCell id="mt" value="Multi-tenancy design" style="swimlane;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;startSize=24;" vertex="1" parent="1">
          <mxGeometry x="40" y="450" width="720" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="mt1" value="1. Header&#xa;X-Tenant-Id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="mt">
          <mxGeometry x="20" y="35" width="100" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="mt2" value="2. TenantContext&#xa;ThreadLocal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="mt">
          <mxGeometry x="150" y="35" width="110" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="mt3" value="3. Every repo&#xa;WHERE tenant_id=?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="mt">
          <mxGeometry x="290" y="35" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="mt4" value="4. RLS policies&#xa;(SQL ready)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="mt">
          <mxGeometry x="440" y="35" width="110" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="mt5" value="5. Events&#xa;tenantId field" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="mt">
          <mxGeometry x="580" y="35" width="110" height="50" as="geometry"/>
        </mxCell>

        <!-- relationships -->
        <mxCell id="r1" style="endArrow=ERmany;startArrow=ERone;endFill=0;startFill=0;strokeColor=#9673a6;" edge="1" parent="1" source="tenant" target="cust"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r2" style="endArrow=ERmany;startArrow=ERone;endFill=0;startFill=0;strokeColor=#82b366;" edge="1" parent="1" source="tenant" target="inv"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r3" style="endArrow=ERmany;startArrow=ERone;endFill=0;startFill=0;strokeColor=#82b366;" edge="1" parent="1" source="tenant" target="pay"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r4" style="endArrow=ERmany;startArrow=ERone;endFill=0;startFill=0;strokeColor=#82b366;" edge="1" parent="1" source="inv" target="line"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r5" style="endArrow=ERmany;startArrow=ERone;endFill=0;startFill=0;strokeColor=#d79b00;" edge="1" parent="1" source="inv" target="alloc"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r6" style="endArrow=ERmany;startArrow=ERone;endFill=0;startFill=0;strokeColor=#d79b00;" edge="1" parent="1" source="pay" target="alloc"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r7" style="endArrow=ERmany;startArrow=ERone;endFill=0;startFill=0;strokeColor=#9673a6;dashed=1;" edge="1" parent="1" source="cust" target="inv"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="r8" style="endArrow=ERmany;startArrow=ERone;endFill=0;startFill=0;strokeColor=#d6b656;" edge="1" parent="1" source="pay" target="chq"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="foot" value="★ Aggregate roots · All tables carry tenant_id · UUID v7 ids · Money NUMERIC(19,2)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=9;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="140" y="560" width="520" height="18" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="payment" name="Payment Design">
    <mxGraphModel dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="pt" value="Design: Payment Record &amp; Allocation" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontStyle=1;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="180" y="10" width="440" height="24" as="geometry"/>
        </mxCell>

        <!-- Record path -->
        <mxCell id="pr" value="Record Payment" style="swimlane;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=11;startSize=24;" vertex="1" parent="1">
          <mxGeometry x="40" y="50" width="720" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="p1" value="POST /payments&#xa;PaymentResource" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="pr">
          <mxGeometry x="20" y="35" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p2" value="RecordPaymentService&#xa;load Customer&#xa;dup check number" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="pr">
          <mxGeometry x="170" y="35" width="140" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p3" value="new Payment&#xa;RECEIVED&#xa;amount_unallocated" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="pr">
          <mxGeometry x="340" y="35" width="130" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p4" value="PaymentRepository&#xa;+ Audit save" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="pr">
          <mxGeometry x="500" y="35" width="120" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="p5" value="201&#xa;{id, number}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="pr">
          <mxGeometry x="640" y="35" width="60" height="50" as="geometry"/>
        </mxCell>

        <!-- Allocation -->
        <mxCell id="al" value="Allocation (FIFO or Manual)" style="swimlane;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=11;startSize=24;" vertex="1" parent="1">
          <mxGeometry x="40" y="170" width="720" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="a1p" value="POST …/allocate/fifo&#xa;or …/allocate/manual&#xa;+ Idempotency-Key" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="al">
          <mxGeometry x="20" y="40" width="140" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="a2p" value="PaymentAllocationService&#xa;idempotency cache&#xa;(in-memory ConcurrentMap)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="al">
          <mxGeometry x="180" y="40" width="160" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="a3p" value="Load Payment&#xa;Load open Invoices&#xa;for customer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="al">
          <mxGeometry x="360" y="40" width="140" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="a4p" value="PaymentAllocationEngine&#xa;FIFO: dueDate, issueDate&#xa;Manual: explicit amounts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="al">
          <mxGeometry x="520" y="40" width="180" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="a5p" value="payment.allocate(...)&#xa;amount_unallocated ↓" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="al">
          <mxGeometry x="100" y="120" width="160" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="a6p" value="Save Payment + Allocations&#xa;Update invoice status&#xa;PAID / PARTIALLY_PAID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;" vertex="1" parent="al">
          <mxGeometry x="300" y="120" width="180" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="a7p" value="Rules&#xa;amount &gt; 0&#xa;currency match&#xa;≤ unallocated" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="al">
          <mxGeometry x="520" y="120" width="160" height="55" as="geometry"/>
        </mxCell>

        <!-- Cheque parallel -->
        <mxCell id="cq" value="Cheque parallel path (instrument lifecycle)" style="swimlane;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=11;startSize=24;" vertex="1" parent="1">
          <mxGeometry x="40" y="390" width="720" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="c1" value="RECEIVED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontStyle=1;" vertex="1" parent="cq">
          <mxGeometry x="30" y="40" width="90" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="c2" value="DEPOSITED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;" vertex="1" parent="cq">
          <mxGeometry x="180" y="40" width="90" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="c3" value="CLEARED&#xa;Dr Bank / Cr AR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=9;fontStyle=1;" vertex="1" parent="cq">
          <mxGeometry x="340" y="35" width="110" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="c4" value="BOUNCED&#xa;reverse + reopen inv" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=9;fontStyle=1;" vertex="1" parent="cq">
          <mxGeometry x="510" y="35" width="130" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="ce1" style="endArrow=block;endFill=1;strokeColor=#666666;" edge="1" parent="cq" source="c1" target="c2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce2" style="endArrow=block;endFill=1;strokeColor=#82b366;" edge="1" parent="cq" source="c2" target="c3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce3" style="endArrow=block;endFill=1;strokeColor=#b85450;dashed=1;" edge="1" parent="cq" source="c2" target="c4">
          <mxGeometry relative="1" as="geometry">
            <Array as="points"><mxPoint x="225" y="85"/><mxPoint x="575" y="85"/></Array>
          </mxGeometry>
        </mxCell>

        <mxCell id="pn" value="Shortcut: POST /invoices/{id}/payment only updates invoice status (no Payment aggregate)." style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=9;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="100" y="510" width="600" height="18" as="geometry"/>
        </mxCell>
        <mxCell id="pn2" value="FIFO open-invoice query matches customerRef to customer UUID string." style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=9;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="100" y="530" width="600" height="18" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
