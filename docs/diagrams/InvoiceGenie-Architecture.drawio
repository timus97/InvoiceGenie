        <!-- Driven adapters -->
        <mxCell id="driven" value="DRIVEN ADAPTERS (Outbound)" style="swimlane;horizontal=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=10;startSize=28;" vertex="1" parent="1">
          <mxGeometry x="40" y="475" width="720" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="pers" value="ar-adapter-persistence&#xa;JPA Entities · Mappers&#xa;*RepositoryAdapter&#xa;PostgreSQL / H2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;" vertex="1" parent="driven">
          <mxGeometry x="40" y="15" width="200" height="72" as="geometry"/>
        </mxCell>
        <mxCell id="msg" value="ar-adapter-messaging&#xa;KafkaEventPublisher (outbox write)&#xa;OutboxWorker (poll · publish stub)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;" vertex="1" parent="driven">
          <mxGeometry x="260" y="15" width="230" height="72" as="geometry"/>
        </mxCell>
        <mxCell id="infra" value="Infrastructure&#xa;Postgres · Kafka (opt)&#xa;UUID v7 · CDI" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#999999;fontSize=10;" vertex="1" parent="driven">
          <mxGeometry x="510" y="15" width="180" height="72" as="geometry"/>
        </mxCell>

        <!-- Bootstrap + kernel -->
        <mxCell id="boot" value="ar-bootstrap · ArApplication (CDI wiring) · application.yml" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="590" width="340" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="kernel" value="shared-kernel · TenantId · Money · UuidV7 · TenantContext · DomainEvent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="590" width="360" height="40" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;html=1;endArrow=block;endFill=1;strokeWidth=2;strokeColor=#6c8ebf;" edge="1" parent="1" source="client" target="drive">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e1l" value="X-Tenant-Id" style="edgeLabel;html=1;align=center;fontSize=9;fontColor=#6c8ebf;" vertex="1" connectable="0" parent="e1">
