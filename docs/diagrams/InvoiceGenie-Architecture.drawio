        <mxCell id="cust" value="Customer&#xa;ar_customer&#xa;code · credit_limit · status" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="40" y="130" width="140" height="70" as="geometry"/>
