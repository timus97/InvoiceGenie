        <!-- Application -->
        <mxCell id="app" value="APPLICATION LAYER — ar-application&#xa;Use Cases · Inbound / Outbound Ports" style="swimlane;horizontal=0;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=10;startSize=28;" vertex="1" parent="1">
          <mxGeometry x="40" y="250" width="720" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="uc1" value="IssueInvoice&#xa;Get / List" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="app">
          <mxGeometry x="40" y="18" width="100" height="58" as="geometry"/>
        </mxCell>
        <mxCell id="uc2" value="InvoiceLifecycle&#xa;overdue · write-off" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="app">
          <mxGeometry x="155" y="18" width="110" height="58" as="geometry"/>
        </mxCell>
        <mxCell id="uc3" value="RecordPayment&#xa;Allocation FIFO/Manual" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="app">
          <mxGeometry x="280" y="18" width="130" height="58" as="geometry"/>
