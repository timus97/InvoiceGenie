        <mxCell id="agg1" value="Invoice + Lines&#xa;LifecycleEngine" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="dom">
