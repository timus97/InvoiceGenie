        <mxCell id="ports" value="Outbound Ports&#xa;EventPublisher · IdGenerator&#xa;+ Domain Repos" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="app">
