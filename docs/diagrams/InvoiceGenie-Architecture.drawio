  <diagram id="design" name="Invoice Flow Design">
    <mxGraphModel dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="dt" value="Design: Create / Issue Invoice (canonical vertical slice)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontStyle=1;fontSize=15;" vertex="1" parent="1">
          <mxGeometry x="120" y="8" width="560" height="24" as="geometry"/>
        </mxCell>
        <mxCell id="dt2" value="POST /api/v1/invoices  +  X-Tenant-Id" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="220" y="30" width="360" height="18" as="geometry"/>
        </mxCell>

        <!-- Flow steps left to right, then down -->
        <mxCell id="s1" value="1. TenantFilter&#xa;parse X-Tenant-Id&#xa;TenantContext.set" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="140" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="s2" value="2. InvoiceResource&#xa;map DTO → command&#xa;getCurrentTenant()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="70" width="150" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="s3" value="3. IssueInvoiceService&#xa;IdGenerator (UuidV7)&#xa;build Invoice + lines" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="410" y="70" width="160" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="s4" value="4. Invoice.issue()&#xa;LifecycleEngine&#xa;DRAFT → ISSUED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="610" y="70" width="150" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="s5" value="5. InvoiceRepository.save&#xa;InvoiceRepositoryAdapter&#xa;Entity + Lines merge" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="610" y="190" width="150" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="s6" value="6. AuditRepository.save&#xa;AuditEntry after-state&#xa;ar_audit_log" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="410" y="190" width="150" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="s7" value="7. EventPublisher&#xa;KafkaEventPublisher&#xa;OutboxEntry PENDING" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="190" width="150" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="s8" value="8. HTTP 201&#xa;{ id }&#xa;Clear TenantContext" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="190" width="140" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="async" value="ASYNC — OutboxWorker (@Scheduled every 5s)" style="swimlane;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=11;startSize=28;" vertex="1" parent="1">
          <mxGeometry x="40" y="300" width="720" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="a1" value="findPending(batch)&#xa;ar_outbox" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="async">
          <mxGeometry x="30" y="40" width="140" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="a2" value="mark PROCESSING&#xa;prevent duplicates" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="async">
          <mxGeometry x="200" y="40" width="140" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="a3" value="Publish Kafka&#xa;(stub / commented)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#999999;fontSize=10;fontStyle=2;" vertex="1" parent="async">
          <mxGeometry x="370" y="40" width="140" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="a4" value="PUBLISHED / FAILED&#xa;retry_count · cleanup" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;" vertex="1" parent="async">
          <mxGeometry x="540" y="40" width="150" height="55" as="geometry"/>
        </mxCell>

        <!-- Same TX box -->
        <mxCell id="tx" value="Same DB transaction (aggregate + audit + outbox write)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=10;fontStyle=2;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="220" y="270" width="400" height="20" as="geometry"/>
        </mxCell>

        <!-- Lifecycle mini -->
        <mxCell id="lc" value="Invoice status machine (InvoiceLifecycleEngine)" style="swimlane;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;startSize=26;" vertex="1" parent="1">
          <mxGeometry x="40" y="430" width="720" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="st1" value="DRAFT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=10;fontStyle=1;" vertex="1" parent="lc">
          <mxGeometry x="20" y="40" width="70" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="st2" value="ISSUED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;fontStyle=1;" vertex="1" parent="lc">
          <mxGeometry x="130" y="40" width="70" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="st3" value="PARTIALLY&#xa;PAID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=9;fontStyle=1;" vertex="1" parent="lc">
          <mxGeometry x="240" y="35" width="80" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="st4" value="PAID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;fontStyle=1;" vertex="1" parent="lc">
          <mxGeometry x="360" y="40" width="70" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="st5" value="OVERDUE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;fontStyle=1;" vertex="1" parent="lc">
