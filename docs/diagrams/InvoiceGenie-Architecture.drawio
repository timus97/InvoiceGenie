        <mxCell id="t2" value="Arrows mean depends-on (compile). Domain has zero infrastructure deps." style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=10;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="160" y="36" width="480" height="18" as="geometry"/>
        </mxCell>

