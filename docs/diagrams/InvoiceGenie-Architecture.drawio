<mxfile host="app.diagrams.net" agent="InvoiceGenie">
  <diagram id="arch" name="Architecture">
    <mxGraphModel dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="InvoiceGenie — Hexagonal Architecture" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontSize=16;fontColor=#1a1a2e;" vertex="1" parent="1">
          <mxGeometry x="180" y="10" width="440" height="28" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="Java 17 · Quarkus 3.6 · DDD · Multi-tenant AR Backend" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="200" y="34" width="400" height="20" as="geometry"/>
        </mxCell>

        <!-- Client -->
        <mxCell id="client" value="Clients&#xa;curl · Postman · Swagger" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="300" y="60" width="200" height="48" as="geometry"/>
        </mxCell>

        <!-- Driving adapter swimlane -->
        <mxCell id="drive" value="DRIVING ADAPTERS (Inbound)" style="swimlane;horizontal=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=10;startSize=28;" vertex="1" parent="1">
          <mxGeometry x="40" y="130" width="720" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="filters" value="Filters&#xa;TenantFilter&#xa;Logging · Clear" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="drive">
          <mxGeometry x="40" y="20" width="120" height="68" as="geometry"/>
        </mxCell>
        <mxCell id="rest" value="ar-adapter-api&#xa;InvoiceResource · PaymentResource&#xa;Cheque · Aging · Ledger · Customer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;fontStyle=1;" vertex="1" parent="drive">
          <mxGeometry x="180" y="20" width="280" height="68" as="geometry"/>
        </mxCell>
        <mxCell id="err" value="GlobalException&#xa;Mapper&#xa;400 / 409 / 500" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="drive">
          <mxGeometry x="480" y="20" width="120" height="68" as="geometry"/>
