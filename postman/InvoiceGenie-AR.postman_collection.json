        },
        {
          "name": "List Credit Notes",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/credit-notes?status={{creditNoteStatus}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "credit-notes"],
              "query": [
                { "key": "status", "value": "{{creditNoteStatus}}" }
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "tenantId", "value": "00000000-0000-0000-0000-000000000001" },
    { "key": "invoiceId", "value": "" },
    { "key": "paymentId", "value": "" },
    { "key": "chequeId", "value": "" },
    { "key": "creditNoteId", "value": "" },
    { "key": "idempotencyKey", "value": "" },
    { "key": "limit", "value": "20" },
    { "key": "cursor", "value": "" },
