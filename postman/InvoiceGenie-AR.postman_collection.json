{
  "info": {
    "name": "InvoiceGenie AR API",
    "description": "Postman collection for InvoiceGenie AR backend.\n\nAuth/Tenancy:\n- Tenant is required on every call: header `X-Tenant-Id: {{tenantId}}`.\n- Optional idempotency: `Idempotency-Key: {{idempotencyKey}}` on create.\n\nBase URL:\n- Default: {{baseUrl}} (e.g. http://localhost:8080)\n- SQLite profile runs on 8081 in application.yml.\n",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Ensure we always have an idempotency key available",
          "if (!pm.environment.get('idempotencyKey')) {",
          "  pm.environment.set('idempotencyKey', pm.variables.replaceIn('{{$guid}}'));",
          "}",
          "// Generate random values",
          "pm.environment.set('randomInt', Math.floor(Math.random() * 1000000));"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Health & Info",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/q/health",
              "host": ["{{baseUrl}}"],
              "path": ["q", "health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "OpenAPI Spec",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/q/openapi",
              "host": ["{{baseUrl}}"],
              "path": ["q", "openapi"]
            }
          }
        }
      ]
    },
    {
      "name": "Invoices",
      "item": [
        {
          "name": "Create + Issue Invoice",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" },
              { "key": "Idempotency-Key", "value": "{{idempotencyKey}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/invoices",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "invoices"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"invoiceNumber\": \"INV-{{randomInt}}\",\n  \"customerRef\": \"CUST-001\",\n  \"currencyCode\": \"USD\",\n  \"dueDate\": \"2026-12-31\",\n  \"lines\": [\n    { \"sequence\": 1, \"description\": \"Consulting\", \"amount\": 1250.00 },\n    { \"sequence\": 2, \"description\": \"License\", \"amount\": 250.00 }\n  ]\n}\n"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json && json.id) {",
                  "  pm.environment.set('invoiceId', json.id);",
                  "  pm.environment.set('invoiceAmount', json.total);",
                  "}",
                  "const loc = pm.response.headers.get('Location');",
                  "if (loc) {",
                  "  const m = loc.match(/\\/api\\/v1\\/invoices\\/([0-9a-fA-F-]{36})$/);",
                  "  if (m && m[1]) pm.environment.set('invoiceId', m[1]);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Invoice by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/invoices/{{invoiceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "invoices", "{{invoiceId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "List Invoices (page)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/invoices?limit={{limit}}&cursor={{cursor}}&status={{status}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "invoices"],
              "query": [
                { "key": "limit", "value": "{{limit}}" },
                { "key": "cursor", "value": "{{cursor}}" },
                { "key": "status", "value": "{{status}}" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json && json.nextCursor) {",
                  "  pm.environment.set('cursor', json.nextCursor);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Issue Invoice (DRAFT → ISSUED)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/invoices/{{invoiceId}}/issue",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "invoices", "{{invoiceId}}", "issue"]
            }
          }
        },
        {
          "name": "Mark Overdue",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/invoices/{{invoiceId}}/overdue?today={{today}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "invoices", "{{invoiceId}}", "overdue"],
              "query": [
                { "key": "today", "value": "{{today}}" }
              ]
            }
          }
        },
        {
          "name": "Write Off Invoice",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/invoices/{{invoiceId}}/writeoff",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "invoices", "{{invoiceId}}", "writeoff"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Customer dispute resolved by credit\"\n}\n"
            }
          }
        },
        {
          "name": "Apply Payment Status",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/invoices/{{invoiceId}}/payment",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "invoices", "{{invoiceId}}", "payment"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullyPaid\": true\n}\n"
            }
          }
        },
        {
          "name": "Update Due Date (DRAFT only)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/invoices/{{invoiceId}}/due-date",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "invoices", "{{invoiceId}}", "due-date"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dueDate\": \"2027-01-31\"\n}\n"
            }
          }
        },
        {
          "name": "Delete Invoice (should be 405)",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/invoices/{{invoiceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "invoices", "{{invoiceId}}"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('405 Method Not Allowed', function () {",
                  "  pm.response.to.have.status(405);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Payment Allocation - FIFO",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments/{{paymentId}}/allocate/fifo",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments", "{{paymentId}}", "allocate", "fifo"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"allocatedBy\": \"{{tenantId}}\",\n  \"version\": 1\n}\n"
            }
          }
        },
        {
          "name": "Payment Allocation - Manual",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments/{{paymentId}}/allocate/manual",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments", "{{paymentId}}", "allocate", "manual"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"allocatedBy\": \"{{tenantId}}\",\n  \"version\": 1,\n  \"allocations\": [\n    {\n      \"invoiceId\": \"{{invoiceId}}\",\n      \"amount\": 100.00,\n      \"notes\": \"Manual allocation\"\n    }\n  ]\n}\n"
            }
          }
        },
        {
          "name": "Get Payment Allocations",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments/{{paymentId}}/allocations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments", "{{paymentId}}", "allocations"]
            }
          }
        },
        {
          "name": "Get Invoice Allocations",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/payments/invoices/{{invoiceId}}/allocations",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "payments", "invoices", "{{invoiceId}}", "allocations"]
            }
          }
        }
      ]
    },
    {
      "name": "Ledger",
      "item": [
        {
          "name": "List Accounts",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/ledger/accounts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "ledger", "accounts"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Account Balance",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/ledger/balance/{{account}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "ledger", "balance", "{{account}}"]
            }
          }
        },
        {
          "name": "Get Transaction",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/ledger/transactions/{{transactionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "ledger", "transactions", "{{transactionId}}"]
            }
          }
        },
        {
          "name": "Get Entries by Reference",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/ledger/reference/INVOICE/{{invoiceId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "ledger", "reference", "INVOICE", "{{invoiceId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Cheques",
      "item": [
        {
          "name": "Create Cheque (RECEIVED)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/cheques",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "cheques"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"chequeNumber\": \"CHQ-{{randomInt}}\",\n  \"customerId\": \"{{tenantId}}\",\n  \"amount\": 1000.00,\n  \"currencyCode\": \"USD\",\n  \"bankName\": \"Test Bank\",\n  \"bankBranch\": \"Main Branch\",\n  \"chequeDate\": \"2026-03-20\",\n  \"notes\": \"Test cheque\"\n}\n"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "let json = {};",
                  "try { json = pm.response.json(); } catch (e) {}",
                  "if (json && json.id) {",
                  "  pm.environment.set('chequeId', json.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Deposit Cheque (RECEIVED → DEPOSITED)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/cheques/{{chequeId}}/deposit",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "cheques", "{{chequeId}}", "deposit"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('200 OK', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Clear Cheque (DEPOSITED → CLEARED)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/cheques/{{chequeId}}/clear",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "cheques", "{{chequeId}}", "clear"]
            }
          }
        },
        {
          "name": "Bounce Cheque (DEPOSITED → BOUNCED)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/cheques/{{chequeId}}/bounce",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "cheques", "{{chequeId}}", "bounce"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Insufficient funds\"\n}\n"
            }
          }
        },
        {
          "name": "Get Cheque by ID",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/cheques/{{chequeId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "cheques", "{{chequeId}}"]
            }
          }
        },
        {
          "name": "List Cheques",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-Tenant-Id", "value": "{{tenantId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/cheques?status={{chequeStatus}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "cheques"],
              "query": [
                { "key": "status", "value": "{{chequeStatus}}" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Aging Reports",
